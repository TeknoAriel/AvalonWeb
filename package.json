{
  "name": "avalon-monorepo",
  "private": true,
  "scripts": {
    "kp:verify-premier": "bash scripts/verify-kiteprop-api-premier.sh",
    "bff:verify-catalog": "bash scripts/verify-bff-catalog.sh",
    "kp:ingest-stats": "tsx scripts/kiteprop-ingest-stats.ts",
    "catalog:regenerate-snapshot": "tsx scripts/regenerate-properties-snapshot.ts",
    "ci:verify-ingest": "bash scripts/ci-verify-kiteprop-ingest.sh",
    "ci:verify-cron-prod": "bash scripts/ci-verify-production-cron.sh",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:avalon": "turbo dev --filter=avalon-propiedades",
    "dev:premier": "turbo dev --filter=avalon-premier",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "check:premier-snapshot": "tsx scripts/check-premier-snapshot.ts"
  },
  "devDependencies": {
    "next": "^14.2.21",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
