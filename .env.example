# KiteProp (catálogo + CRM): ver docs/KITEPROP.md

# Funciones UI (coma). Ej: nl_search,property_ask
# NEXT_PUBLIC_DISABLED_FEATURES=

# Curadura extra listado Premier (opcional)
# PREMIER_MIN_GALLERY_IMAGES=1
# PREMIER_MIN_TOTAL_M2=40
# PREMIER_EXCLUDE_PROPERTY_IDS=123,456

# Puente server-to-server hacia herramientas tipo MCP (opcional). POST { tool, args } → { ok, result }
# KITEPROP_MCP_BRIDGE_URL=https://tu-bridge.example.com/mcp

# URL pública del sitio (cada proyecto Vercel)
# En local: localhost. En Vercel conviene la URL canónica del proyecto (p. ej. https://avalonweb.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URLs cruzadas entre marcas (local)
NEXT_PUBLIC_AVALON_URL=http://localhost:3000
NEXT_PUBLIC_PREMIER_URL=http://localhost:3001

# Enlace explícito al otro sitio (opcional). Si no hay PEER ni PREMIER/AVALON URL, el código usa por defecto
# https://avalon-premier.vercel.app y https://avalonweb.vercel.app para enlaces cruzados.
# NEXT_PUBLIC_PEER_SITE_URL=http://localhost:3001

# WhatsApp en formato internacional sin +
NEXT_PUBLIC_WHATSAPP=543416811434

# Opcional: forzar IDs como Premier para QA (se excluyen del sitio estándar)
# PREMIER_PROPERTY_IDS=123,456
# NEXT_PUBLIC_PREMIER_PROPERTY_IDS=123,456

# Avalon Premier — Videos de portada (coma). Formas: VIDEO_ID | VIDEO_ID@segInicio-segFin | URL con start/end
# Ejemplo recorte 5s–30s: kSllrnwFhnA@5-30
# NEXT_PUBLIC_PREMIER_COVER_VIDEOS=kSllrnwFhnA@5-30

# Hero fullscreen (MP4 u origen compatible con <video>; si está vacío se usa imagen del feed)
# NEXT_PUBLIC_PREMIER_HERO_VIDEO_URL=https://ejemplo.com/hero-premier.mp4

# --- KiteProp API (servidor) — detalle en docs/KITEPROP.md ---
# Host sin /api/v1 (consultas). Con key: messages (ficha) / contacts (general).
# KITEPROP_API_URL=https://www.kiteprop.com
# (alternativa) KITEPROP_API_BASE_URL=https://www.kiteprop.com/api/v1
# KITEPROP_API_KEY=kp_...
# (alias) KITEPROP_API_TOKEN=kp_...
# Opcional: ruta del listado si tu tenant usa otro path
# KITEPROP_API_PROPERTIES_PATH=/properties
# Filtro status en listado (default active)
# KITEPROP_API_STATUS_FILTER=active
# Tamaño de página API (10–100, default 50)
# KITEPROP_API_PER_PAGE=50

# Opcional: URL completa de un POST legacy (sobrescribe messages/contacts; cuerpo plano full_name, etc.)
# KITEPROP_API_CONSULTA_URL=https://...

# Feed JSON público (mismo esquema que packages/core/data/properties.json). Respaldo si no hay API key o la API no devuelve filas.
# Premier filtra por tag/flag Premier; Avalon excluye ese inventario. Con KITEPROP_API_KEY, el catálogo sale primero de GET /properties.
# Ejemplo difusión KiteProp (externalsite):
# KITEPROP_PROPERTIES_JSON_URL=https://static.kiteprop.com/kp/difusions/4b3c894a10d905c82e85b35c410d7d4099551504/externalsite-2-9e4f284e1578b24afa155c578d05821ac4c56baa.json

# ISR: POST /api/revalidate?secret=... (solo servidor)
# REVALIDATE_SECRET=

# Cron Vercel (cada 2 h): GET /api/cron/refresh-catalog — en Vercel, con CRON_SECRET definido, el cron envía Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
